generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  VIEWER
  ADMIN
}

enum Plan {
  FREE
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  GRACE
}

enum RenewalType {
  NONE
  AUTO_CARD
  MANUAL_MPESA
}

enum EventType {
  ONBOARDING_COMPLETED
  PLAY_START
  PLAY_PROGRESS
  PLAY_COMPLETE
  PLAY_ABANDON
  SKIP
  LIKE
  DISLIKE
  WATCHLIST_ADD
  WATCHLIST_REMOVE
  SEARCH
  SEARCH_NO_RESULTS
}

enum TitleType {
  FILM
  SERIES
  PODCAST
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum VideoStatus {
  PROCESSING
  READY
  ERROR
}

// ---------------------------------------------------------------------------
// Auth.js v5 models (@auth/prisma-adapter)
// ---------------------------------------------------------------------------

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime? @map("email_verified")
  image          String?
  hashedPassword String?   @map("hashed_password")
  role           Role      @default(VIEWER)
  isDeleted      Boolean   @default(false) @map("is_deleted")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  accounts            Account[]
  sessions            Session[]
  profile             Profile?
  subscription        Subscription?
  passwordResetTokens PasswordResetToken[]
  watchEvents         WatchEvent[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  expires   DateTime
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// ---------------------------------------------------------------------------
// Taxonomy
// ---------------------------------------------------------------------------

model Genre {
  id           String  @id @default(cuid())
  slug         String  @unique
  name         String
  isActive     Boolean @default(true) @map("is_active")
  displayOrder Int     @default(0) @map("display_order")

  profiles Profile[] @relation("ProfileGenres")
  titles   Title[]   @relation("TitleGenres")

  @@map("genres")
}

model Language {
  id       String  @id @default(cuid())
  code     String  @unique
  name     String
  isActive Boolean @default(true) @map("is_active")

  profiles Profile[] @relation("ProfileLanguages")
  titles   Title[]   @relation("TitleLanguages")

  @@map("languages")
}

// ---------------------------------------------------------------------------
// App models
// ---------------------------------------------------------------------------

model Profile {
  id                  String   @id @default(cuid())
  userId              String   @unique @map("user_id")
  preferences         Json     @default("{}")
  onboardingCompleted Boolean  @default(false) @map("onboarding_completed")
  avatarUrl           String?  @map("avatar_url")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  genres             Genre[]    @relation("ProfileGenres")
  preferredLanguages Language[] @relation("ProfileLanguages")

  @@map("profiles")
}

model Subscription {
  id               String             @id @default(cuid())
  userId           String             @unique @map("user_id")
  plan             Plan               @default(FREE)
  status           SubscriptionStatus @default(ACTIVE)
  renewalType      RenewalType        @default(NONE)
  currentPeriodEnd DateTime?          @map("current_period_end")
  isDeleted        Boolean            @default(false) @map("is_deleted")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model WatchEvent {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  titleId   String?   @map("title_id")
  episodeId String?   @map("episode_id")
  type      EventType
  value     Float?
  metadata  Json?
  createdAt DateTime  @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title   Title?   @relation(fields: [titleId], references: [id], onDelete: SetNull)
  episode Episode? @relation(fields: [episodeId], references: [id], onDelete: SetNull)

  @@index([userId, type])
  @@index([titleId])
  @@map("watch_events")
}

// ---------------------------------------------------------------------------
// Content models
// ---------------------------------------------------------------------------

model Title {
  id             String        @id @default(cuid())
  type           TitleType
  title          String
  slug           String        @unique
  synopsis       String?
  releaseYear    Int?          @map("release_year")
  maturityRating String?       @map("maturity_rating")
  isPremium      Boolean       @default(false) @map("is_premium")
  status         ContentStatus @default(DRAFT)
  posterUrl      String?       @map("poster_url")
  backdropUrl    String?       @map("backdrop_url")
  trailerUrl     String?       @map("trailer_url")
  isDeleted      Boolean       @default(false) @map("is_deleted")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  genres      Genre[]      @relation("TitleGenres")
  languages   Language[]   @relation("TitleLanguages")
  seasons     Season[]
  episodes    Episode[]
  collections Collection[] @relation("CollectionTitles")
  watchEvents WatchEvent[]

  @@index([status])
  @@map("titles")
}

model Season {
  id        String   @id @default(cuid())
  titleId   String   @map("title_id")
  number    Int
  name      String?
  isDeleted Boolean  @default(false) @map("is_deleted")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  title    Title     @relation(fields: [titleId], references: [id], onDelete: Cascade)
  episodes Episode[]

  @@map("seasons")
}

model Episode {
  id           String      @id @default(cuid())
  titleId      String      @map("title_id")
  seasonId     String?     @map("season_id")
  number       Int
  title        String?
  synopsis     String?
  bunnyVideoId String?     @map("bunny_video_id")
  status       VideoStatus @default(PROCESSING)
  durationSec  Int?        @map("duration_sec")
  thumbnailUrl String?     @map("thumbnail_url")
  isDeleted    Boolean     @default(false) @map("is_deleted")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  parentTitle Title      @relation(fields: [titleId], references: [id], onDelete: Cascade)
  season      Season?    @relation(fields: [seasonId], references: [id])
  watchEvents WatchEvent[]

  @@index([titleId])
  @@index([bunnyVideoId])
  @@map("episodes")
}

model Collection {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  description  String?
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  isDeleted    Boolean  @default(false) @map("is_deleted")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  titles Title[] @relation("CollectionTitles")

  @@map("collections")
}
